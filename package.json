{
  "name": "alexa-marine-skill",
  "version": "1.0.0",
  "description": "Amazon Alexa skill for marine weather, tides, and NOAA data",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint lambda/ tests/",
    "lint:fix": "eslint --fix lambda/ tests/"
  },
  "devDependencies": {
    "ask-sdk-core": "^2.14.0",
    "ask-sdk-model": "^1.86.0",
    "axios": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "prettier": "^3.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "coverageThreshold": {
      "global": {
        "statements": 80,
        "branches": 75,
        "functions": 80,
        "lines": 80
      }
    },
    "collectCoverageFrom": [
      "lambda/**/*.js",
      "!lambda/index.js"
    ]
  }
}
